./lang test5a/$1.lang out.xml
RETVAL=$?
if [ $RETVAL -ne 0 ] 
then
  cp out.xml out2.xml
else
  xmllint --format out.xml -o out2.xml
  RETVAL=$?
  [ $RETVAL -ne 0 ] && echo $1 FAILED ----- && exit
fi

diff -bwB out2.xml test5a/$1.correct
RETVAL=$?
[ $RETVAL -eq 0 ] && echo $1 PASSED
[ $RETVAL -ne 0 ] && echo $1 FAILED -----
exit $RETVAL
