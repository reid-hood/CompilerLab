// Reid Hood - Test stack preservation across nested function calls
// Tests that local variables are preserved after function calls return
program
{
    int square(int x)
    {
        return x * x;
    }
    
    int add(int a, int b)
    {
        return a + b;
    }
    
    int compute(int n)
    {
        int temp;
        int result;
        temp = square(n);
        result = add(temp, square(n + 1));
        return result;
    }
    
    int x;
    int y;
    
    x = 5;
    y = compute(x);
    
    // x should still be 5 after nested calls
    print(x);
    // 5^2 + 6^2 = 25 + 36 = 61
    print(y);
}
