// Reid Hood - Comprehensive test: sum and product calculations
program
{
    int sum_range(int from, int to)
    {
        int sum;
        int i;

        sum = 0;
        i = from;

        while (i <= to)
        {
            sum = sum + i;
            i = i + 1;
        }

        return sum;
    }

    int product_range(int from, int to)
    {
        int prod;
        int i;

        prod = 1;
        i = from;

        while (i <= to)
        {
            prod = prod * i;
            i = i + 1;
        }

        return prod;
    }

    print(sum_range(1, 5));
    print(product_range(1, 5));
    print(sum_range(10, 12));
    print(product_range(2, 4));
}

