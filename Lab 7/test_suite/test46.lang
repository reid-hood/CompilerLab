// Reid Hood - Test counting and accumulation pattern
program
{
    int count_evens(int limit)
    {
        int count;
        int i;

        count = 0;
        i = 0;

        while (i < limit)
        {
            if (i % 2 == 0)
                count = count + 1;
            endif;
            i = i + 1;
        }

        return count;
    }

    print(count_evens(10));
    print(count_evens(5));
}
