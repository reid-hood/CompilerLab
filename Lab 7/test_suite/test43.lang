// Reid Hood - Test array with complex expressions in loop
program
{
    array int [10] squares;
    int i;
    
    i = 0;
    while (i < 5)
    {
        squares[i] = (i + 1) * (i + 1);
        i = i + 1;
    }
    
    i = 0;
    while (i < 5)
    {
        print(squares[i]);
        i = i + 1;
    }
}
