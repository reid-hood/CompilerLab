// Reid Hood - Test mixed if-else and while with multiple functions
program
{
    int gcd(int a, int b)
    {
        while (b != 0)
        {
            int temp;
            temp = b;
            b = a % b;
            a = temp;
        }
        return a;
    }

    int max(int x, int y)
    {
        if (x > y)
            return x;
        else
            return y;
        endif;
    }

    print(gcd(48, 18));
    print(max(100, 50));
    print(max(25, 75));
}
